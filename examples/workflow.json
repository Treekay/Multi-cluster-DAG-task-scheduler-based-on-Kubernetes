{
  "name": "sample-etl",
  "tasks": [
    {
      "name": "extract",
      "image": "busybox:1.36",
      "command": ["sh", "-c", "echo extract"],
      "resources": {
        "cpu": 1,
        "memoryMiB": 128
      }
    },
    {
      "name": "transform",
      "image": "busybox:1.36",
      "command": ["sh", "-c", "echo transform"],
      "dependsOn": ["extract"],
      "resources": {
        "cpu": 2,
        "memoryMiB": 256
      }
    },
    {
      "name": "load",
      "image": "busybox:1.36",
      "command": ["sh", "-c", "echo load"],
      "dependsOn": ["transform"],
      "resources": {
        "cpu": 1,
        "memoryMiB": 128
      }
    }
  ]
}
